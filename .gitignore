# YouLend Loan Platform - Root .gitignore


# ============================================================
# OS Files
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# ============================================================
# IDE / Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.swn
.history/
*.code-workspace

# ============================================================
# Backend (.NET)
# ============================================================
backend/bin/
backend/obj/
backend/**/*.user
backend/**/*.suo
backend/**/.vs/
backend/**/TestResults/
backend/**/*.trx
backend/**/coverage/
backend/**/*.coverage

# ============================================================
# Frontend (Angular/Node)
# ============================================================
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/.nx/
frontend/coverage/
frontend/**/*.log
frontend/**/.env.local
frontend/**/.env.*.local

# ============================================================
# Docker
# ============================================================
docker-compose.override.yml

# ============================================================
# Terraform
# ============================================================
infrastructure/terraform/.terraform/
infrastructure/terraform/**/*.tfstate
infrastructure/terraform/**/*.tfstate.*
infrastructure/terraform/**/*.tfvars
infrastructure/terraform/**/crash.log
infrastructure/terraform/**/crash.*.log
infrastructure/terraform/**/.terraform.lock.hcl
infrastructure/terraform/**/override.tf
infrastructure/terraform/**/override.tf.json
infrastructure/terraform/**/*_override.tf
infrastructure/terraform/**/*_override.tf.json
infrastructure/terraform/**/.terraformrc
infrastructure/terraform/**/terraform.rc
infrastructure/terraform/**/tfplan

# ============================================================
# Kubernetes
# ============================================================
infrastructure/k8s/secrets.yaml
infrastructure/helm/**/secrets.yaml

# ============================================================
# Secrets & Credentials (NEVER COMMIT!)
# ============================================================
*.pem
*.key
*.cert
*.p12
*.pfx

# Environment files with sensitive data
frontend/src/environments/environment.ts
frontend/src/environments/environment.prod.ts
.env
.env.local
.env.production
.env.staging
.env.*.local

# Monitoring configuration with passwords
infrastructure/monitoring/grafana-values.yaml

secrets/
credentials/
*.credentials
**/appsettings.Development.json

# AWS
.aws/
*.aws

# Auth0
auth0.json
.auth0/
auth0-config.json
*auth0-credentials*

# ============================================================
# Logs
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ============================================================
# Temporary Files
# ============================================================
tmp/
temp/
*.tmp
*.bak
*.backup
*.cache

# ============================================================
# Build Artifacts
# ============================================================
dist/
build/
out/
*.tar.gz
*.zip

# ============================================================
# Test Coverage
# ============================================================
coverage/
.nyc_output/
*.lcov

# ============================================================
# Package Manager
# ============================================================
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnpm-store/

# Keep these if team uses specific package manager
# !package-lock.json
# !yarn.lock

# ============================================================
# System Files
# ============================================================
.DS_Store
.idea
.vscode
*.swp
*.swo
*~
.history
