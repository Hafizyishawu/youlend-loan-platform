# YouLend Environment Configuration Template
# Copy this file to .env and fill in your values

# ================================
# Auth0 Configuration
# ================================
# Get these from your Auth0 Dashboard > Applications > Your App
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-client-id-here

# ================================
# API Configuration  
# ================================
API_URL=http://localhost:5001/api/v1
FRONTEND_URL=http://localhost:4200

# ================================
# Demo Mode (for quick testing)
# ================================
# Set to true to skip Auth0 setup
DEMO_MODE=false

# ================================
# Production Settings
# ================================
# Only needed for production deployment
PRODUCTION_DOMAIN=your-domain.com
PRODUCTION_API_URL=https://your-domain.com/api/v1

# ================================
# AWS Configuration (for deployment)
# ================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
CLUSTER_NAME=youlend-eks

# ================================
# Monitoring
# ================================
GRAFANA_ADMIN_PASSWORD=your-secure-password-here

# Instructions:
# 1. Copy this file: cp .env.template .env
# 2. Fill in your Auth0 credentials
# 3. Or set DEMO_MODE=true for quick testing
# 4. Never commit the .env file to git!